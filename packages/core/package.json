{
  "name": "@garrison-hq/sortie",
  "version": "1.0.0-pre.1",
  "license": "AGPL-3.0-only",
  "description": "Local-first web agents: semantic extraction, multi-step browser automation, web search, and URL-to-Markdown fetch — natural-language goal in, schema-validated JSON out",
  "keywords": [
    "web-agent",
    "browser-automation",
    "playwright",
    "web-scraping",
    "semantic-extraction",
    "llm",
    "web-search",
    "mcp",
    "local-first"
  ],
  "author": "Jeroen Nouws",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garrison-hq/sortie.git",
    "directory": "packages/core"
  },
  "homepage": "https://garrison-hq.github.io/sortie/",
  "bugs": "https://github.com/garrison-hq/sortie/issues",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "sortie": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.0",
    "@mozilla/readability": "^0.6.0",
