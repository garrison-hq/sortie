{
  "name": "nanofish",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first web-agent automation platform: query and act on the web like it were an API",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@anthropic-ai/claude-code"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @nanofish/server dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
