# --- LLM providers (set at least one) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
# Override to point at any OpenAI-compatible endpoint (Ollama, vLLM, OpenRouter, ...)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Which provider the agent uses by default: "anthropic" | "openai"
NANOFISH_PROVIDER=anthropic

# --- Web search ---
# Optional self-hosted SearXNG instance — the preferred search backend
# (structured JSON, no CAPTCHAs). When unset, `search` falls back to driving
# real engines in a headless browser (Bing -> DuckDuckGo -> Brave); engines
# that present a CAPTCHA are skipped, never bypassed. With the compose
# "search" profile, use: SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_BASE_URL=

# --- Server ---
NANOFISH_HOST=0.0.0.0
NANOFISH_PORT=3470

# --- Storage (SQLite db, sessions, exports live here) ---
NANOFISH_DATA_DIR=./data

# --- Site credentials for agent logins ---
# Any variable here can be exposed to an agent by NAME via the CLI (--cred NAME),
# batch specs ("credentialNames"), or MCP run_agent credentials ("env:NAME").
# The model only ever sees the {{cred:NAME}} placeholder — never the value.

# Demo credentials for saucedemo.com (used by the demo flows) — the public
# demo username/password are printed on https://www.saucedemo.com itself:
SAUCEDEMO_USERNAME=
SAUCEDEMO_PASSWORD=

# User-specific placeholders — fill in with your own account if you use these flows:
COLLECTANDGO_USERNAME=
COLLECTANDGO_PASSWORD=
