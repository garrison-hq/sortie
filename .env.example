# --- LLM providers (set at least one) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
# Override to point at any OpenAI-compatible endpoint (Ollama, vLLM, OpenRouter, ...)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Which provider the agent uses by default: "anthropic" | "openai"
NANOFISH_PROVIDER=anthropic

# --- Server ---
NANOFISH_HOST=0.0.0.0
NANOFISH_PORT=3470

# --- Storage (SQLite db, sessions, exports live here) ---
NANOFISH_DATA_DIR=./data

# --- Site credentials for agent logins (referenced by name from agent configs) ---
# Example used by the saucedemo demo:
SAUCEDEMO_USERNAME=standard_user
SAUCEDEMO_PASSWORD=secret_sauce
