{
  "name": "@garrison-hq/sortie-server",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "description": "sortie API server — Fastify REST + WebSocket live view; serves the built UI in production",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garrison-hq/sortie.git",
    "directory": "apps/server"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@garrison-hq/sortie": "workspace:*",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.2"
  }
